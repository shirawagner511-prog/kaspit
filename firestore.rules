rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(householdId) {
      let d = get(/databases/$(database)/documents/households/$(householdId)).data;
      return 'memberUids' in d && request.auth.uid in d.memberUids;
    }

    match /subscriptions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/subscriptions/$(uid));
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public read for username availability checks before login.
    // Write: authenticated user may create their own username entry only if it doesn't exist.
    // Delete/update from client is denied — usernames are permanent handles.
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /households/{householdId} {
      allow read: if request.auth != null
        && 'memberUids' in resource.data
        && request.auth.uid in resource.data.memberUids;

      // Creator must be the sole initial member; client cannot forge a multi-member create.
      allow create: if request.auth != null
        && request.resource.data.memberUids == [request.auth.uid]
        && request.resource.data.members.size() == 1;

      // Existing members may update household metadata.
      // A non-member may add themselves only if the invite code matches and they don't remove existing members.
      allow update: if request.auth != null
        && 'memberUids' in resource.data
        && (
          // Already a member
          request.auth.uid in resource.data.memberUids
          ||
          // Joining via invite code: adding only themselves, code must match
          (
            !(request.auth.uid in resource.data.memberUids)
            && resource.data.inviteCode == request.resource.data.inviteCode
            && request.resource.data.memberUids.toSet().hasAll(resource.data.memberUids)
            && request.resource.data.memberUids.hasAll([request.auth.uid])
          )
        )
        && request.resource.data.memberUids.toSet().hasAll(resource.data.memberUids);

      match /entries/{entryId} {
        allow read: if request.auth != null && isMember(householdId);
        allow create: if request.auth != null
          && isMember(householdId)
          && request.resource.data.keys().hasAll(['date', 'amount', 'type'])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.type in ['expense', 'income', 'saving'];
        allow update, delete: if request.auth != null && isMember(householdId);
      }

      match /accounts/{accountId} {
        allow read, write: if request.auth != null && isMember(householdId);
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && isMember(householdId);
      }

      match /monthlySummaries/{summaryId} {
        allow read: if request.auth != null && isMember(householdId);
        allow write: if request.auth != null && isMember(householdId);
      }
    }
  }
}
