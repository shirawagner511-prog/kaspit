rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can write only their own profile
    // Any authenticated user can read other users (needed for household member names)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Households: readable/writable by members only
    // Anyone authenticated can query by inviteCode (needed for joining)
    match /households/{householdId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.query.limit <= 1
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;

      // Entries: only household members can access
      match /entries/{entryId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }
  }
}
